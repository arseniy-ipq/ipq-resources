---
// SEO base layout — every page gets clean <head> meta, canonical, OG, and sitewide
// Organization JSON-LD. Content ships as static HTML so Google AND AI crawlers can read it.
// Article pages (any page passing `published`) also get: kicker + byline row (updated date,
// reading time) injected around their existing <h1>/lede, plus Article JSON-LD.
const {
  title,
  description,
  canonical = Astro.url.pathname,
  published,
  updated,
  kicker = 'The IPQ Field Guide',
} = Astro.props;
// ⚠ build-time internal form — publish.sh canonicalizes to https://ipqmedia.com/resources
// at deploy. Do NOT append /resources here: new URL(pathname, site) drops subpaths.
const site = 'https://resources.ipqmedia.com';
const canonicalUrl = new URL(canonical, site).href;
const ogImage = `${site}/og-card.png`;
const author = {
  '@type': 'Person',
  name: 'Arseniy Volosevich',
  jobTitle: 'Founder',
  image: `${site}/author-arseniy.jpg`,
  worksFor: { '@type': 'Organization', name: 'IPQmedia', url: 'https://ipqmedia.com' },
  url: 'https://ipqmedia.com',
};
const org = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'IPQmedia',
  url: 'https://ipqmedia.com',
  description:
    'Lead generation and client acquisition for US architecture firms.',
  founder: author,
  sameAs: ['https://www.linkedin.com/company/ipqmedia'],
};

// Render the page content to a string so we can compute reading time and
// inject the article header without touching the page files themselves.
let body = await Astro.slots.render('default');
const words = body.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim().split(' ').length;
const mins = Math.max(2, Math.round(words / 220));
const fmt = (d) =>
  new Date(d + 'T00:00:00Z').toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });

let article = null;
if (published) {
  const byline = `<div class="byline"><img class="by-avatar" src="/author-arseniy.jpg" width="44" height="44" alt="Arseniy Volosevich" loading="lazy" decoding="async" /><span class="by-brand">Arseniy Volosevich</span><span class="by-role">Founder, IPQmedia</span><span class="dot">·</span><span>Updated ${fmt(updated || published)}</span><span class="dot">·</span><span>${mins} min read</span></div>`;
  body = body.replace(/<h1([^>]*)>/, `<p class="kicker">${kicker}</p><h1$1>`);
  if (/<p class="lede">/.test(body)) {
    body = body.replace(/(<p class="lede">[\s\S]*?<\/p>)/, `$1${byline}`);
  } else {
    body = body.replace(/<\/h1>/, `</h1>${byline}`);
  }
  article = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title.replace(/ \| IPQmedia$/, ''),
    description,
    author,
    publisher: {
      '@type': 'Organization',
      name: 'IPQmedia',
      url: 'https://ipqmedia.com',
      logo: { '@type': 'ImageObject', url: `${site}/ipqmedia-logo.png` },
    },
    datePublished: published,
    dateModified: updated || published,
    mainEntityOfPage: canonicalUrl,
    image: [ogImage],
  };
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <!-- PostHog analytics — same project + host as the ipqmedia.com funnel, so /resources traffic
         lands in the same project (219455). Loads on every page via this shared layout. -->
    <script is:inline>
      !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug getPageViewId captureTraceFeedback captureTraceMetric".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
      posthog.init('phc_ymEGg7n8BrCgAcsVLH7UFKRawkpSvgASVgMJpYMEGyvX',{api_host:'https://eu.i.posthog.com',defaults:'2025-05-24'})
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={published ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="IPQmedia" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="IPQmedia. The IPQ Field Guide: marketing and client acquisition guides for architecture firms." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="robots" content="index,follow" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(org)} />
    {article && <script is:inline type="application/ld+json" set:html={JSON.stringify(article)} />}
  </head>
  <body>
    <header class="site-head">
      <a href="/" class="brand"><img src="/ipqmedia-logo.png" alt="IPQmedia" class="logo" width="1434" height="300" /></a>
      <a href="https://beam.ipqmedia.com/program" class="cta">Book a call</a>
    </header>
    <main class="wrap">
      <Fragment set:html={body} />
    </main>
    <footer class="site-foot">
      <span>© IPQmedia. Client acquisition for US architecture firms.</span>
      <a href="https://ipqmedia.com">ipqmedia.com</a>
    </footer>
    <style is:global>
      :root {
        --ink: #16161a;
        --dim: #52525e;
        --faint: #8a8a96;
        --red: #ea4942;
        --line: #e8e8ee;
        --bg: #ffffff;
        --soft: #faf9fb;
        --serif: Charter, 'Iowan Old Style', 'Palatino Linotype', Cambria, Georgia, serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, Helvetica, Arial, sans-serif;
        color: var(--ink);
        background: var(--bg);
        line-height: 1.7;
        font-size: 20px;
        -webkit-font-smoothing: antialiased;
      }
      .site-head, .site-foot {
        display: flex; align-items: center; justify-content: space-between;
        max-width: 920px; margin: 0 auto; padding: 18px 24px;
      }
      .brand { display: inline-flex; align-items: center; }
      .logo { height: 34px; width: auto; display: block; }
      .cta { text-decoration: none; background: var(--red); color: #fff; font-weight: 600; font-size: 14px; padding: 9px 16px; border-radius: 8px; }
      .cta-block { display: inline-block; text-decoration: none; background: var(--red); color: #fff; font-weight: 600; font-size: 16px; padding: 13px 24px; border-radius: 10px; margin-top: 8px; }
      .wrap { max-width: 760px; margin: 0 auto; padding: 24px 24px 72px; }
      h1, h2, h3 { font-family: var(--serif); font-weight: 600; }
      h1 { font-size: 48px; line-height: 1.12; letter-spacing: -0.015em; margin: 22px 0 18px; }
      h2 { font-size: 31px; line-height: 1.25; letter-spacing: -0.01em; margin: 60px 0 16px; }
      h2::before { content: ''; display: block; width: 34px; height: 3px; background: var(--red); border-radius: 2px; margin-bottom: 18px; }
      h3 { font-size: 23px; margin: 36px 0 10px; }
      p { margin: 0 0 24px; }
      ul, ol { margin: 0 0 24px; padding-left: 24px; }
      li { margin-bottom: 12px; }
      li::marker { color: var(--red); }
      a { color: var(--red); text-underline-offset: 3px; text-decoration-thickness: 1px; }
      .lede { font-family: var(--serif); font-size: 24px; line-height: 1.55; color: var(--dim); margin: 0 0 20px; }
      .kicker { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin: 26px 0 0; }
      .kicker + h1 { margin-top: 10px; }
      .byline {
        display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
        font-size: 14px; color: var(--faint);
        border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
        padding: 12px 2px; margin: 8px 0 42px;
      }
      .byline .by-avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; margin-right: 2px; }
      .byline .by-brand { color: var(--ink); font-weight: 600; }
      .byline .by-role { color: var(--faint); }
      .byline .dot { color: var(--line); }
      blockquote { margin: 0 0 24px; padding: 2px 0 2px 20px; border-left: 3px solid var(--red); font-family: var(--serif); font-size: 21px; color: var(--dim); }
      .answer { border: 1px solid var(--line); border-left: 3px solid var(--red); border-radius: 10px; background: var(--soft); padding: 16px 20px 4px; margin: 0 0 26px; }
      .answer .answer-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.09em; color: var(--red); margin: 0 0 8px; }
      .answer p { margin-bottom: 14px; }
      table { width: 100%; border-collapse: collapse; margin: 4px 0 26px; font-size: 17px; line-height: 1.5; }
      th { text-align: left; font-size: 12.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--dim); padding: 8px 12px 8px 0; border-bottom: 2px solid var(--ink); }
      td { padding: 10px 12px 10px 0; border-bottom: 1px solid var(--line); vertical-align: top; }
      td:first-child { font-weight: 600; }
      @media (max-width: 640px) {
        table { font-size: 14px; display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
        th, td { padding-right: 8px; }
        th, td { min-width: 90px; }
      }
      .card-grid { display: grid; gap: 14px; margin: 24px 0; }
      .card { border: 1px solid var(--line); border-radius: 12px; padding: 18px 20px; text-decoration: none; color: var(--ink); background: var(--soft); transition: border-color .15s; }
      .card:hover { border-color: var(--red); }
      .card h3 { margin: 0 0 4px; }
      .card p { margin: 0; color: var(--dim); font-size: 16px; }
      .site-foot { border-top: 1px solid var(--line); margin-top: 40px; font-size: 13px; color: var(--faint); }
      .site-foot a { color: var(--faint); }
      @media (max-width: 640px) {
        body { font-size: 17px; }
        h1 { font-size: 33px; }
        h2 { font-size: 25px; margin-top: 50px; }
        h3 { font-size: 20px; }
        .lede { font-size: 20px; }
        .wrap { padding: 16px 20px 56px; }
      }
    </style>
  </body>
</html>
